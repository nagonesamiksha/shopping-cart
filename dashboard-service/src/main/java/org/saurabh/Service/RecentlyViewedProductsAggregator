import org.apache.kafka.streams.kstream.Aggregator;

public class RecentlyViewedProductsAggregator implements Aggregator<String, String, String> {
    @Override
    public String apply(String key, String newValue, String aggregate) {
        // Parse the JSON strings into JSON arrays
        JSONArray newProducts = new JSONArray(newValue);
        JSONArray existingProducts = new JSONArray(aggregate);

        // Merge the new products with the existing products
        for (int i = 0; i < newProducts.length(); i++) {
            existingProducts.put(newProducts.getJSONObject(i));
        }

        // Return the merged JSON array as a string
        return existingProducts.toString();
    }
}
